# ============================================
# Atlas CMS Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ============================================
# MAILGUN EMAIL SERVICE
# ============================================
# Get these from: https://app.mailgun.com/
# See docs/MAILGUN_SETUP.md for detailed setup instructions

# Your Mailgun private API key (starts with "key-")
MAILGUN_API_KEY=key-your_private_api_key_here

# Your Mailgun domain
# For testing: Use sandbox domain like sandbox123abc456def.mailgun.org
# For production: Use your verified domain like mg.yourdomain.com
MAILGUN_DOMAIN=sandbox123abc456def.mailgun.org

# From address for outgoing emails
# Must match your Mailgun domain
MAILGUN_FROM=Atlas CMS <noreply@sandbox123abc456def.mailgun.org>

# Optional: Mailgun region (default: us)
# MAILGUN_REGION=us  # or 'eu' for European data residency

# ============================================
# APPLICATION SETTINGS
# ============================================

# Super admin email address (receives submission notifications)
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# Your application URL (used for links in emails)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email service API endpoint (leave as default unless customizing)
NEXT_PUBLIC_EMAIL_SERVICE_URL=/api/send-email

# ============================================
# DATABASE (SUPABASE)
# ============================================
# Get these from: https://app.supabase.com/project/_/settings/api
# See docs/SUPABASE_SETUP.md for detailed setup instructions

# Your Supabase project URL (find in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous public key (find in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service role key (NEVER expose this to the client!)
# Only use on the server side for admin operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# FUTURE: AUTHENTICATION
# ============================================
# These will be needed for user authentication
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=generate_a_random_secret_here
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================
# CLOUDINARY (IF USING)
# ============================================
# For image/file uploads
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
# Enable verbose logging
# DEBUG=true

# Disable email sending (useful for testing)
# DISABLE_EMAILS=true
